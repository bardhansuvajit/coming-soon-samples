<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Orchids Boutique — Coming Soon</title>

<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    darkMode: 'class',
    theme: {
      extend: {
        colors: {
          cream: '#FAF7F0',
          ivory: '#FFFFFF',
          ink: '#1F2A22',
          paper: '#F3EFE2',
          forest: {
            950: '#0A1712',
            900: '#0B1F18',
            800: '#12281F',
            700: '#163C2C',
            600: '#2F6B4F',
            500: '#3F7C5D',
          },
          gold: {
            300: '#F0D284',
            400: '#E3B94F',
            500: '#D9B45C',
            600: '#B8892B',
          },
        },
        fontFamily: {
          cormorant: ['"Cormorant Garamond"', 'serif'],
          jost: ['Jost', 'sans-serif'],
        },
      },
    },
  };
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

<style>
  body { font-family: 'Jost', sans-serif; }

  @keyframes draw { to { stroke-dashoffset: 0; } }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  @keyframes pulseGlow { 0%, 100% { opacity: .45; transform: scale(1); } 50% { opacity: .85; transform: scale(1.18); } }
  @keyframes shimmer { 0% { background-position: 0% 0; } 100% { background-position: 200% 0; } }

  .orchid path,
  .orchid ellipse {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: draw 1.4s ease forwards;
  }

  .orchid-wrap {
    animation: float 6s ease-in-out infinite;
    animation-delay: 2.6s;
  }

  .fade-up {
    opacity: 0;
    animation: fadeUp .9s cubic-bezier(.2,.7,.3,1) forwards;
  }

  .glow-pulse {
    animation: pulseGlow 5s ease-in-out infinite;
  }

  .shimmer-text {
    background-image: linear-gradient(90deg, #B8892B 0%, #F0D284 25%, #B8892B 50%, #F0D284 75%, #B8892B 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 5s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .orchid path, .orchid ellipse, .orchid-wrap, .fade-up, .glow-pulse, .shimmer-text {
      animation: none !important;
      opacity: 1 !important;
      stroke-dashoffset: 0 !important;
      transform: none !important;
      -webkit-text-fill-color: currentColor !important;
    }
  }
</style>
</head>

<body class="bg-cream dark:bg-forest-900 text-ink dark:text-paper transition-colors duration-500">

<div class="flex flex-col min-h-screen">

  <!-- Header -->
  <header class="flex items-center justify-between px-6 sm:px-10 py-5 border-b border-gold-600/20 dark:border-gold-400/20">
    <div class="flex items-center gap-3">
      <svg viewBox="0 0 60 54" class="w-6 h-6 sm:w-7 sm:h-7 text-forest-700 dark:text-gold-400" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M30 30 C24 20 23 10 30 4 C37 10 36 20 30 30 Z"/>
        <path d="M30 31 C20 27 8 25 2 30 C10 34 20 33 30 31 Z"/>
        <path d="M30 31 C40 27 52 25 58 30 C50 34 40 33 30 31 Z"/>
        <path d="M30 31 C27 38 25 44 30 50 C35 44 33 38 30 31 Z"/>
        <circle cx="30" cy="29" r="2.2" fill="currentColor" stroke="none"/>
      </svg>
      <span class="text-xs sm:text-sm tracking-[0.25em] uppercase font-medium text-forest-700 dark:text-gold-300">Orchids Boutique</span>
    </div>

    <button id="themeToggle" aria-label="Toggle dark and light theme" class="rounded-full border border-gold-600/40 dark:border-gold-400/40 p-2 hover:bg-gold-600/10 dark:hover:bg-gold-400/10 transition focus:outline-none focus:ring-2 focus:ring-gold-500">
      <svg class="w-4 h-4 sm:w-5 sm:h-5 block dark:hidden text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <circle cx="12" cy="12" r="4.5"/>
        <path stroke-linecap="round" d="M12 2.5v2M12 19.5v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2.5 12h2M19.5 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>
      </svg>
      <svg class="w-4 h-4 sm:w-5 sm:h-5 hidden dark:block text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.5 14.5A8.5 8.5 0 1 1 9.5 3.5a7 7 0 0 0 11 11Z"/>
      </svg>
    </button>
  </header>

  <!-- Main -->
  <main class="flex-1 grid lg:grid-cols-2">

    <!-- Illustration panel -->
    <section class="relative flex items-center justify-center h-72 sm:h-96 lg:h-auto py-12 px-8 bg-forest-700 dark:bg-forest-950 overflow-hidden">
      <span class="absolute top-6 left-6 w-10 h-10 border-t border-l border-gold-400/50"></span>
      <span class="absolute bottom-6 right-6 w-10 h-10 border-b border-r border-gold-400/50"></span>
      <div class="glow-pulse absolute w-64 h-64 sm:w-80 sm:h-80 bg-gold-500/20 blur-3xl rounded-full"></div>

      <div class="orchid-wrap relative">
        <svg class="orchid w-40 sm:w-56 lg:w-64 h-auto text-gold-400" viewBox="0 0 400 600" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path pathLength="1" style="animation-delay:.05s" d="M200 600 C190 500 215 430 198 350"/>
          <path pathLength="1" style="animation-delay:.12s" d="M170 560 C120 530 105 470 145 420 C175 460 185 520 170 560 Z"/>
          <path pathLength="1" style="animation-delay:.18s" d="M230 560 C280 530 295 470 255 420 C225 460 215 520 230 560 Z"/>
          <path pathLength="1" style="animation-delay:.28s" d="M198 470 C215 465 230 450 235 430"/>
          <path pathLength="1" style="animation-delay:.34s" d="M235 430 C245 415 245 400 233 388 C223 400 223 418 235 430 Z"/>
          <path pathLength="1" style="animation-delay:.4s" d="M198 400 C182 395 168 382 162 365"/>
          <path pathLength="1" style="animation-delay:.46s" d="M162 365 C152 352 152 337 164 327 C174 340 174 356 162 365 Z"/>
          <path pathLength="1" style="animation-delay:.58s" d="M200 260 C180 220 176 172 200 138 C224 172 220 220 200 260 Z"/>
          <path pathLength="1" style="animation-delay:.68s" d="M200 262 C150 244 100 232 68 256 C100 278 152 272 200 262 Z"/>
          <path pathLength="1" style="animation-delay:.74s" d="M200 262 C250 244 300 232 332 256 C300 278 248 272 200 262 Z"/>
          <path pathLength="1" style="animation-delay:.84s" d="M200 262 C168 292 128 320 108 362 C142 350 178 320 200 262 Z"/>
          <path pathLength="1" style="animation-delay:.9s" d="M200 262 C232 292 272 320 292 362 C258 350 222 320 200 262 Z"/>
          <path pathLength="1" style="animation-delay:1.02s" d="M200 262 C186 300 176 330 200 366 C224 330 214 300 200 262 Z"/>
          <path pathLength="1" style="animation-delay:1.14s" d="M182 330 C190 340 210 340 218 330"/>
          <ellipse pathLength="1" style="animation-delay:1.2s" cx="200" cy="258" rx="6" ry="9"/>
        </svg>
      </div>
    </section>

    <!-- Content panel -->
    <section class="flex flex-col justify-center gap-6 px-6 sm:px-12 lg:px-20 py-16">

      <p class="fade-up text-xs tracking-[0.3em] uppercase text-gold-600 dark:text-gold-400 font-medium" style="animation-delay:.1s">Opening Soon</p>

      <h1 class="fade-up font-cormorant italic text-5xl sm:text-6xl lg:text-7xl leading-[1.05] text-forest-700 dark:text-paper" style="animation-delay:.2s">
        Orchids<br class="hidden sm:block" /> Boutique
      </h1>

      <p class="fade-up shimmer-text font-cormorant text-lg sm:text-xl tracking-wide text-gold-600 dark:text-gold-400" style="animation-delay:.3s">
        Tradition with Elegance
      </p>

      <p class="fade-up max-w-md text-sm sm:text-base leading-relaxed font-light text-ink/70 dark:text-paper/70" style="animation-delay:.4s">
        Curated pieces, gathered quietly over years of travel and craft, are preparing to find new homes. Our doors open soon — join the list to hear first.
      </p>

      <form id="notifyForm" class="fade-up flex flex-col sm:flex-row gap-3 max-w-md" style="animation-delay:.5s">
        <label for="email" class="sr-only">Email address</label>
        <input
          id="email"
          type="email"
          required
          placeholder="Your email address"
          class="flex-1 px-4 py-3 border border-forest-700/20 dark:border-gold-400/30 bg-ivory dark:bg-forest-800 text-ink dark:text-paper placeholder:text-ink/40 dark:placeholder:text-paper/40 text-sm focus:outline-none focus:ring-2 focus:ring-gold-500"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-forest-700 dark:bg-gold-500 text-paper dark:text-forest-900 text-sm uppercase tracking-widest hover:bg-forest-600 dark:hover:bg-gold-400 transition focus:outline-none focus:ring-2 focus:ring-gold-500"
        >Notify Me</button>
      </form>
      <p id="formMsg" class="hidden text-sm text-gold-600 dark:text-gold-400">Thank you — you're on the list. We'll be in touch.</p>

      <div class="fade-up flex gap-5 sm:gap-8" style="animation-delay:.6s">
        <div class="text-center">
          <span id="cd-days" class="block text-2xl sm:text-3xl font-cormorant text-forest-700 dark:text-gold-300">00</span>
          <span class="block text-[10px] tracking-widest uppercase text-ink/50 dark:text-paper/50 mt-1">Days</span>
        </div>
        <div class="text-center border-l border-gold-600/20 dark:border-gold-400/20 pl-5 sm:pl-8">
          <span id="cd-hours" class="block text-2xl sm:text-3xl font-cormorant text-forest-700 dark:text-gold-300">00</span>
          <span class="block text-[10px] tracking-widest uppercase text-ink/50 dark:text-paper/50 mt-1">Hours</span>
        </div>
        <div class="text-center border-l border-gold-600/20 dark:border-gold-400/20 pl-5 sm:pl-8">
          <span id="cd-minutes" class="block text-2xl sm:text-3xl font-cormorant text-forest-700 dark:text-gold-300">00</span>
          <span class="block text-[10px] tracking-widest uppercase text-ink/50 dark:text-paper/50 mt-1">Minutes</span>
        </div>
        <div class="text-center border-l border-gold-600/20 dark:border-gold-400/20 pl-5 sm:pl-8">
          <span id="cd-seconds" class="block text-2xl sm:text-3xl font-cormorant text-forest-700 dark:text-gold-300">00</span>
          <span class="block text-[10px] tracking-widest uppercase text-ink/50 dark:text-paper/50 mt-1">Seconds</span>
        </div>
      </div>

      <div class="fade-up flex gap-3" style="animation-delay:.7s">
        <a href="#" aria-label="Facebook" class="rounded-full border border-gold-600/30 dark:border-gold-400/30 p-2.5 hover:bg-gold-600/10 dark:hover:bg-gold-400/10 transition text-forest-700 dark:text-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M14 21v-7h2.4l.4-3.2H14V8.9c0-.9.4-1.4 1.5-1.4H17V4.1c-.4-.1-1.3-.1-2.3-.1-2.3 0-3.7 1.5-3.7 4.1v2.7H9v3.2h2V21"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="rounded-full border border-gold-600/30 dark:border-gold-400/30 p-2.5 hover:bg-gold-600/10 dark:hover:bg-gold-400/10 transition text-forest-700 dark:text-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="0.6" fill="currentColor"/></svg>
        </a>
        <a href="#" aria-label="YouTube" class="rounded-full border border-gold-600/30 dark:border-gold-400/30 p-2.5 hover:bg-gold-600/10 dark:hover:bg-gold-400/10 transition text-forest-700 dark:text-gold-300 focus:outline-none focus:ring-2 focus:ring-gold-500">
          <svg class="w-4 h-4" viewBox="0 0 24 24"><rect x="2.5" y="6" width="19" height="12" rx="4" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M10.5 9.5v5l4.5-2.5Z" fill="currentColor"/></svg>
        </a>
      </div>

    </section>
  </main>

  <!-- Footer -->
  <footer class="py-6 px-6 text-center border-t border-gold-600/20 dark:border-gold-400/20">
    <p class="text-gold-500/60 dark:text-gold-400/50 text-xs tracking-[0.5em] mb-2">❖ ❖ ❖ ❖ ❖ ❖ ❖ ❖ ❖</p>
    <p class="text-[11px] tracking-widest uppercase text-ink/50 dark:text-paper/40">© 2026 Orchids Boutique. All Rights Reserved.</p>
  </footer>

</div>

<script>
  // Theme toggle
  document.getElementById('themeToggle').addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
  });

  // Countdown — placeholder target 45 days from page load
  const target = Date.now() + 45 * 24 * 60 * 60 * 1000;
  const els = {
    d: document.getElementById('cd-days'),
    h: document.getElementById('cd-hours'),
    m: document.getElementById('cd-minutes'),
    s: document.getElementById('cd-seconds'),
  };
  function tick() {
    const diff = Math.max(0, target - Date.now());
    els.d.textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
    els.h.textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
    els.m.textContent = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
    els.s.textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
  }
  tick();
  setInterval(tick, 1000);

  // Email form
  const form = document.getElementById('notifyForm');
  const msg = document.getElementById('formMsg');
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    msg.classList.remove('hidden');
  });
</script>

</body>
</html>
